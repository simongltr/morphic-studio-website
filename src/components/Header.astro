---
import Logo from "./Logo.astro";
import { Icon } from "astro-icon/components";
import { withBase } from "../utils/url";

const home = withBase("/");
---

<header class="site-header">
  <div class="site-header__pill" id="header-pill" data-menu-open="false">
    <span class="site-header__highlight" id="header-highlight"></span>
    <a class="site-header__left" href={home} aria-label="Morphic Studio">
      <span class="site-header__logo">
        <Logo />
      </span>
      <span class="site-header__name">MORPHIC STUDIO</span>
    </a>
    <nav class="site-header__nav" id="header-menu">
      <a href={`${home}#services`}>SERVICES</a>
      <a href={`${home}#methode`}>MÉTHODE</a>
      <a href={`${home}#tarifs`}>TARIFS</a>
      <a href={withBase("/blog")}>BLOG</a>
      <a href={`${home}#contact`}>CONTACT</a>
    </nav>
    <button
      type="button"
      class="site-header__burger"
      id="header-burger"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="header-menu"
    >
      <Icon name="lucide:menu" class="site-header__burger-icon site-header__burger-icon--open" />
      <Icon name="lucide:x" class="site-header__burger-icon site-header__burger-icon--close" />
    </button>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: clamp(0.875rem, 1.6vw, 1.25rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    font-family: "Quicksand", system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
  }
  .site-header__pill {
    position: relative;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow:
      0 6px 24px rgba(0, 0, 0, 0.08),
      0 1px 2px rgba(0, 0, 0, 0.04);
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.6rem;
    gap: clamp(2.5rem, 4vw, 3.5rem);
    white-space: nowrap;
  }
  .site-header__highlight {
    position: absolute;
    top: 50%;
    left: 0;
    height: var(--hl-h, 0px);
    width: var(--hl-w, 0px);
    transform: translate(var(--hl-x, 0px), -50%);
    background: rgba(0, 0, 0, 0.07);
    border-radius: 999px;
    pointer-events: none;
    opacity: var(--hl-o, 0);
    transition:
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
      width 320ms cubic-bezier(0.22, 1, 0.36, 1),
      height 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
    z-index: 0;
  }
  .site-header__highlight--instant {
    transition: opacity 180ms ease;
  }
  .site-header__left {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.35rem 0.85rem 0.35rem 0.55rem;
    border-radius: 999px;
    color: #000;
    text-decoration: none;
  }
  .site-header__logo {
    display: inline-flex;
    align-items: center;
    height: 22px;
  }
  .site-header__logo :global(svg) {
    height: 100%;
    width: auto;
    display: block;
  }
  .site-header__logo :global(svg path) {
    fill: #000;
  }
  .site-header__name {
    color: #000;
    white-space: nowrap;
  }
  .site-header__nav {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .site-header__nav a {
    color: rgba(0, 0, 0, 0.78);
    text-decoration: none;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    transition: color 200ms;
  }
  .site-header__nav a:hover {
    color: #000;
  }

  /* ---------- Burger (mobile only) ---------- */
  .site-header__burger {
    display: none;
    position: relative;
    z-index: 1;
    width: 38px;
    height: 38px;
    margin-left: -0.25rem;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.78);
  }
  .site-header__burger :global(.site-header__burger-icon) {
    width: 20px;
    height: 20px;
    stroke-width: 1.75;
    transition: opacity 180ms ease;
  }
  .site-header__burger :global(.site-header__burger-icon--close) {
    position: absolute;
    opacity: 0;
  }
  .site-header__pill[data-menu-open="true"]
    .site-header__burger :global(.site-header__burger-icon--open) {
    opacity: 0;
  }
  .site-header__pill[data-menu-open="true"]
    .site-header__burger :global(.site-header__burger-icon--close) {
    opacity: 1;
  }

  /* ---------- Mobile layout ---------- */
  @media (max-width: 900px) {
    .site-header__pill {
      gap: 1rem;
      padding: 0.4rem 0.75rem 0.4rem 0.6rem;
    }
    .site-header__highlight {
      display: none;
    }
    .site-header__burger {
      display: inline-flex;
    }
    .site-header__nav {
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      min-width: 220px;
      max-width: calc(100vw - 2rem);
      flex-direction: column;
      align-items: stretch;
      gap: 0.125rem;
      padding: 0.6rem;
      background: rgba(250, 250, 248, 0.97);
      backdrop-filter: blur(18px) saturate(160%);
      -webkit-backdrop-filter: blur(18px) saturate(160%);
      border: 1px solid rgba(0, 0, 0, 0.12);
      border-radius: 18px;
      box-shadow:
        0 16px 40px rgba(0, 0, 0, 0.14),
        0 2px 6px rgba(0, 0, 0, 0.06);
      display: none;
    }
    .site-header__pill[data-menu-open="true"] .site-header__nav {
      display: flex;
    }
    .site-header__nav a {
      text-align: center;
      padding: 0.65rem 0.9rem;
      font-size: 0.75rem;
    }
    .site-header__nav a:hover {
      background: rgba(0, 0, 0, 0.05);
    }
  }
</style>

<script>
  // Sliding white highlight inside the header pill.
  const pill = document.getElementById("header-pill");
  const highlight = document.getElementById("header-highlight");
  if (pill && highlight) {
    const targets = pill.querySelectorAll<HTMLElement>(
      ".site-header__left, .site-header__nav a",
    );
    if (targets.length) {
      let visible = false;

      const place = (target: HTMLElement, instant: boolean) => {
        const pillRect = pill.getBoundingClientRect();
        const r = target.getBoundingClientRect();
        const x = r.left - pillRect.left;
        if (instant) highlight.classList.add("site-header__highlight--instant");
        else highlight.classList.remove("site-header__highlight--instant");
        pill.style.setProperty("--hl-x", x.toFixed(2) + "px");
        pill.style.setProperty("--hl-w", r.width.toFixed(2) + "px");
        pill.style.setProperty("--hl-h", r.height.toFixed(2) + "px");
        if (instant) {
          // Force a frame so the position lands before opacity fades in.
          highlight.getBoundingClientRect();
          highlight.classList.remove("site-header__highlight--instant");
        }
        pill.style.setProperty("--hl-o", "1");
      };

      const hide = () => {
        pill.style.setProperty("--hl-o", "0");
        visible = false;
      };

      targets.forEach((t) => {
        t.addEventListener("mouseenter", () => {
          place(t, !visible);
          visible = true;
        });
      });
      pill.addEventListener("mouseleave", hide);
    }
  }

  // Mobile menu toggle (burger inside the pill).
  const burger = document.getElementById("header-burger");
  const menu = document.getElementById("header-menu");
  if (pill && burger && menu) {
    const setOpen = (open: boolean) => {
      pill.dataset.menuOpen = String(open);
      burger.setAttribute("aria-expanded", String(open));
    };

    burger.addEventListener("click", (event) => {
      event.stopPropagation();
      const isOpen = pill.dataset.menuOpen === "true";
      setOpen(!isOpen);
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && pill.dataset.menuOpen === "true") {
        setOpen(false);
        burger.focus();
      }
    });

    document.addEventListener("click", (event) => {
      if (
        pill.dataset.menuOpen === "true" &&
        !pill.contains(event.target as Node)
      ) {
        setOpen(false);
      }
    });
  }
</script>
