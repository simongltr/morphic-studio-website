---
import Logo from "./Logo.astro";
import { withBase } from "../utils/url";

const home = withBase("/");
---

<header class="site-header">
  <div class="site-header__pill" id="header-pill">
    <span class="site-header__highlight" id="header-highlight"></span>
    <a class="site-header__left" href={home} aria-label="Morphic Studio">
      <span class="site-header__logo">
        <Logo />
      </span>
      <span class="site-header__name">MORPHIC STUDIO</span>
    </a>
    <nav class="site-header__nav">
      <a href={`${home}#services`}>SERVICES</a>
      <a href={`${home}#galerie`}>GALERIE</a>
      <a href={`${home}#tarifs`}>TARIFS</a>
      <a href={withBase("/blog")}>BLOG</a>
      <a href={`${home}#contact`}>CONTACT</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: clamp(0.875rem, 1.6vw, 1.25rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    font-family: "Quicksand", system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
  }
  .site-header__pill {
    position: relative;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow:
      0 6px 24px rgba(0, 0, 0, 0.08),
      0 1px 2px rgba(0, 0, 0, 0.04);
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.5rem;
    gap: clamp(2.25rem, 4vw, 3.25rem);
  }
  .site-header__highlight {
    position: absolute;
    top: 50%;
    left: 0;
    height: var(--hl-h, 0px);
    width: var(--hl-w, 0px);
    transform: translate(var(--hl-x, 0px), -50%);
    background: rgba(0, 0, 0, 0.07);
    border-radius: 999px;
    pointer-events: none;
    opacity: var(--hl-o, 0);
    transition:
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
      width 320ms cubic-bezier(0.22, 1, 0.36, 1),
      height 320ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
    z-index: 0;
  }
  .site-header__highlight--instant {
    transition: opacity 180ms ease;
  }
  .site-header__left {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.35rem 0.85rem 0.35rem 0.55rem;
    border-radius: 999px;
    color: #000;
    text-decoration: none;
  }
  .site-header__logo {
    display: inline-flex;
    align-items: center;
    height: 22px;
  }
  .site-header__logo :global(svg) {
    height: 100%;
    width: auto;
    display: block;
  }
  .site-header__logo :global(svg path) {
    fill: #000;
  }
  .site-header__name {
    color: #000;
  }
  .site-header__nav {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .site-header__nav a {
    color: rgba(0, 0, 0, 0.78);
    text-decoration: none;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    transition: color 200ms;
  }
  .site-header__nav a:hover {
    color: #000;
  }

  @media (max-width: 640px) {
    .site-header__name {
      display: none;
    }
    .site-header__nav {
      gap: 0.75rem;
      font-size: 0.7rem;
    }
  }
</style>

<script>
  // Sliding white highlight inside the header pill.
  const pill = document.getElementById("header-pill");
  const highlight = document.getElementById("header-highlight");
  if (pill && highlight) {
    const targets = pill.querySelectorAll<HTMLElement>(
      ".site-header__left, .site-header__nav a",
    );
    if (targets.length) {
      let visible = false;

      const place = (target: HTMLElement, instant: boolean) => {
        const pillRect = pill.getBoundingClientRect();
        const r = target.getBoundingClientRect();
        const x = r.left - pillRect.left;
        if (instant) highlight.classList.add("site-header__highlight--instant");
        else highlight.classList.remove("site-header__highlight--instant");
        pill.style.setProperty("--hl-x", x.toFixed(2) + "px");
        pill.style.setProperty("--hl-w", r.width.toFixed(2) + "px");
        pill.style.setProperty("--hl-h", r.height.toFixed(2) + "px");
        if (instant) {
          // Force a frame so the position lands before opacity fades in.
          highlight.getBoundingClientRect();
          highlight.classList.remove("site-header__highlight--instant");
        }
        pill.style.setProperty("--hl-o", "1");
      };

      const hide = () => {
        pill.style.setProperty("--hl-o", "0");
        visible = false;
      };

      targets.forEach((t) => {
        t.addEventListener("mouseenter", () => {
          place(t, !visible);
          visible = true;
        });
      });
      pill.addEventListener("mouseleave", hide);
    }
  }
</script>
