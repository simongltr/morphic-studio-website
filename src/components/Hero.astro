---
import Logo from "./Logo.astro";
import { withBase } from "../utils/url";

const heroBgUrl = `url(${withBase("/hero-background.webp")})`;
---

<div class="hero-stage" id="hero-stage">
  <section class="hero" id="hero">
    <div class="hero__bg"></div>
    <img
      class="hero__team"
      src={withBase("/hero-team.webp")}
      alt=""
    />
    <div class="hero__wash"></div>
    <div class="hero__masthead">
      <div class="hero__brand" aria-label="Morphic Studio">
        <span class="hero__brand-logo">
          <Logo />
        </span>
        <span class="hero__brand-name">MORPHIC STUDIO</span>
      </div>
      <h1 class="hero__title">
        Le studio web qui modernise le digital des TPE et PME.
      </h1>
      <p class="hero__subtitle">
        Sites web, boutiques en ligne et outils métier pour lancer un projet,
        améliorer un process ou remplacer un outil interne devenu limitant par
        une solution sur mesure.
      </p>
    </div>
  </section>
</div>

<style define:vars={{ heroBg: heroBgUrl }}>
  .hero-stage {
    position: relative;
    height: 240vh;
    background: #fafaf8;
  }

  .hero {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
    --bg-scale: 1;
    --team-scale: 1;
    --team-blur: 0px;
    --team-opacity: 1;
    --team-x: 0px;
    --team-y: 0px;
    --wash: 0;
    --masthead-top: 42%;
    --team-bottom: -8%;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: var(--heroBg);
    background-size: cover;
    background-position: center;
    transform: scale(var(--bg-scale));
    transform-origin: 50% 45%;
    will-change: transform;
    z-index: 0;
  }

  .hero__masthead {
    position: absolute;
    left: 50%;
    top: var(--masthead-top);
    transform: translate(-50%, -50%);
    /* Fixed 1100px; only shrinks once the viewport edges reach it. */
    width: min(1100px, 95vw);
    text-align: center;
    z-index: 2;
  }

  .hero__brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    margin: 0 auto clamp(1.75rem, 3.83vw, 2.75rem);
    color: rgba(0, 0, 0, 0.82);
  }

  .hero__brand-logo {
    display: inline-flex;
    align-items: center;
    height: clamp(28px, 3.3vw, 38px);
  }

  .hero__brand-logo :global(svg) {
    height: 100%;
    width: auto;
    display: block;
  }

  .hero__brand-logo :global(svg path) {
    fill: currentColor;
  }

  .hero__brand-name {
    font-family: "Quicksand", system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(1.05rem, 1.81vw, 1.3rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .hero__title {
    margin: 0;
    text-align: center;
    font-family: "Libre Baskerville", Georgia, serif;
    font-weight: 700;
    /* Fixed 4.25rem on desktop; only shrinks below ~1150px where the
       text starts reaching the viewport edges. */
    font-size: clamp(2.55rem, 5.9vw, 4.25rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: rgba(0, 0, 0, 0.8);
    text-wrap: balance;
  }

  .hero__subtitle {
    margin: clamp(1.25rem, 2.43vw, 1.75rem) auto 0;
    max-width: min(58rem, 90vw);
    text-align: center;
    font-family: "Quicksand", system-ui, sans-serif;
    font-weight: 500;
    /* Fixed 1rem on desktop, shrinking in step with the title below
       ~1150px (same crossover so the two stay proportional). */
    font-size: clamp(0.6rem, 1.39vw, 1rem);
    letter-spacing: 0.18em;
    color: rgba(0, 0, 0, 0.75);
    text-transform: uppercase;
    line-height: 1.5;
    text-wrap: balance;
  }

  .hero__team {
    position: absolute;
    left: 50%;
    bottom: var(--team-bottom);
    transform: translate(calc(-50% + var(--team-x)), var(--team-y))
      scale(var(--team-scale));
    transform-origin: 50% 65%;
    width: auto;
    height: auto;
    /* Fixed 931px, held even a bit past the viewport width so the edges
       lightly crop the image (centered, clipped by the hero's
       overflow:hidden) before it finally shrinks below ~716px. */
    max-width: min(931px, 130vw);
    object-fit: contain;
    object-position: bottom center;
    pointer-events: none;
    user-select: none;
    filter: blur(var(--team-blur));
    opacity: var(--team-opacity);
    will-change: transform, filter, opacity;
    z-index: 3;
  }

  .hero__wash {
    position: absolute;
    inset: 0;
    background: #fafaf8;
    opacity: var(--wash);
    pointer-events: none;
    z-index: 1;
  }

  /* On phones the proportional size would be too small to read; keep a
     legible minimum (proportions matter less at this width anyway). */
  @media (max-width: 700px) {
    .hero__subtitle {
      font-size: 0.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-stage {
      height: 100vh;
    }
    .hero {
      position: relative;
    }
    .hero__bg {
      transform: none;
    }
    .hero__team {
      filter: none;
      opacity: 1;
    }
    .hero__wash {
      opacity: 0;
    }
  }
</style>

<script>
  const stage = document.getElementById("hero-stage");
  const hero = document.getElementById("hero");
  if (stage && hero) {
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const supportsHover = !window.matchMedia("(hover: none)").matches;

    const BG_SCALE_MAX = 3.0;
    const PARALLAX_MAX_X = 6;
    const PARALLAX_MAX_Y = 3;

    // Composition values interpolate smoothly from "small viewport" → "wide
    // viewport" between 480px and 1100px. Below 480px we lock to the small
    // end; above 1100px we lock to the wide end.
    const SMALL_W = 480;
    const WIDE_W = 1100;
    let TEAM_BLUR_MAX = 24;
    let TEAM_SCALE_MAX = 4.5;
    let MASTHEAD_TOP_START = 41;
    let MASTHEAD_TOP_END = 18;

    let scrollProgress = 0;
    let mouseTargetX = 0;
    let mouseTargetY = 0;
    let mouseCurrentX = 0;
    let mouseCurrentY = 0;
    let raf: number | null = null;
    let needsRender = false;

    const clamp = (v: number, lo: number, hi: number) =>
      v < lo ? lo : v > hi ? hi : v;
    const remap = (
      v: number,
      inA: number,
      inB: number,
      outA: number,
      outB: number,
    ) => {
      const t = clamp((v - inA) / (inB - inA), 0, 1);
      return outA + (outB - outA) * t;
    };

    // Range where the team image must shrink because of horizontal edge
    // constraints (matches the CSS max-width clamp). Inside this range the
    // image rises slightly so it stays close to the subtitle.
    const TEAM_SHRINK_WIDE = 700;
    const TEAM_SHRINK_SMALL = 390;

    const recomputeBreakpointValues = () => {
      const w = window.innerWidth;
      // smallFactor: 1 at SMALL_W, 0 at WIDE_W
      const smallFactor = clamp((WIDE_W - w) / (WIDE_W - SMALL_W), 0, 1);
      const lerp = (wide: number, small: number) =>
        wide + (small - wide) * smallFactor;
      TEAM_BLUR_MAX = lerp(24, 14);
      TEAM_SCALE_MAX = lerp(4.5, 3.5);
      MASTHEAD_TOP_START = lerp(41, 44);
      MASTHEAD_TOP_END = lerp(18, 22);

      const shrinkFactor = clamp(
        (TEAM_SHRINK_WIDE - w) / (TEAM_SHRINK_WIDE - TEAM_SHRINK_SMALL),
        0,
        1,
      );
      const teamBottom = -9 + (2 - -9) * shrinkFactor;
      hero!.style.setProperty("--team-bottom", teamBottom.toFixed(2) + "%");
    };

    const readScroll = () => {
      if (reducedMotion) {
        scrollProgress = 0;
        return;
      }
      const rect = stage.getBoundingClientRect();
      const total = stage.offsetHeight - window.innerHeight;
      if (total <= 0) {
        scrollProgress = 0;
        return;
      }
      scrollProgress = clamp(-rect.top / total, 0, 1);
    };

    const schedule = () => {
      if (raf == null) raf = requestAnimationFrame(tick);
    };

    function tick() {
      raf = null;
      if (supportsHover && !reducedMotion) {
        mouseCurrentX += (mouseTargetX - mouseCurrentX) * 0.08;
        mouseCurrentY += (mouseTargetY - mouseCurrentY) * 0.08;
      }

      const p = scrollProgress;
      const parallaxFade = clamp(1 - p * 2, 0, 1);
      const teamX = mouseCurrentX * PARALLAX_MAX_X * parallaxFade;
      const teamY = mouseCurrentY * PARALLAX_MAX_Y * parallaxFade;
      const bgScale = remap(p, 0, 1, 1, BG_SCALE_MAX);
      const teamScale = remap(p, 0, 0.7, 1, TEAM_SCALE_MAX);
      const teamBlur = remap(p, 0.10, 0.6, 0, TEAM_BLUR_MAX);
      const teamOpacity = remap(p, 0.35, 0.7, 1, 0);
      const wash = remap(p, 0.7, 0.9, 0, 1);
      const mastheadTop = remap(
        p,
        0.85,
        1.0,
        MASTHEAD_TOP_START,
        MASTHEAD_TOP_END,
      );

      hero!.style.setProperty(
        "--masthead-top",
        mastheadTop.toFixed(2) + "%",
      );
      hero!.style.setProperty("--bg-scale", bgScale.toFixed(4));
      hero!.style.setProperty("--team-scale", teamScale.toFixed(4));
      hero!.style.setProperty("--team-blur", teamBlur.toFixed(2) + "px");
      hero!.style.setProperty("--team-opacity", teamOpacity.toFixed(3));
      hero!.style.setProperty("--team-x", teamX.toFixed(2) + "px");
      hero!.style.setProperty("--team-y", teamY.toFixed(2) + "px");
      hero!.style.setProperty("--wash", wash.toFixed(3));

      const mouseSettling =
        supportsHover &&
        (Math.abs(mouseTargetX - mouseCurrentX) > 0.001 ||
          Math.abs(mouseTargetY - mouseCurrentY) > 0.001);
      if (mouseSettling || needsRender) {
        needsRender = false;
        schedule();
      }
    }

    const onScroll = () => {
      readScroll();
      needsRender = true;
      schedule();
    };

    const onResize = () => {
      recomputeBreakpointValues();
      readScroll();
      needsRender = true;
      schedule();
    };

    const onMove = (e: MouseEvent) => {
      if (!supportsHover || reducedMotion) return;
      const rect = hero.getBoundingClientRect();
      mouseTargetX = clamp(
        ((e.clientX - rect.left) / rect.width) * 2 - 1,
        -1,
        1,
      );
      mouseTargetY = clamp(
        ((e.clientY - rect.top) / rect.height) * 2 - 1,
        -1,
        1,
      );
      schedule();
    };

    const onLeave = () => {
      mouseTargetX = 0;
      mouseTargetY = 0;
      schedule();
    };

    recomputeBreakpointValues();
    readScroll();
    needsRender = true;
    schedule();

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onResize);
    if (supportsHover && !reducedMotion) {
      hero.addEventListener("mousemove", onMove);
      hero.addEventListener("mouseleave", onLeave);
    }
  }
</script>
