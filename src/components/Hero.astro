---
import Logo from "./Logo.astro";
import { withBase } from "../utils/url";

const heroBgUrl = `url(${withBase("/hero-background.webp")})`;
---

<div class="hero-stage" id="hero-stage">
  <section class="hero" id="hero">
    <div class="hero__bg"></div>
    <div class="hero__wash"></div>
    <div class="hero__masthead">
      <div class="hero__brand" aria-label="Morphic Studio">
        <span class="hero__brand-logo">
          <Logo />
        </span>
        <span class="hero__brand-name">MORPHIC STUDIO</span>
      </div>
      <h1 class="hero__title">
        Le studio web qui modernise le digital des TPE et PME.
      </h1>
      <p class="hero__subtitle">
        Sites web, boutiques en ligne et outils métier pour lancer un projet,
        améliorer un process ou remplacer un outil interne devenu limitant par
        une solution sur mesure.
      </p>
    </div>
    <img
      class="hero__team"
      src={withBase("/hero-team.webp")}
      alt=""
    />
  </section>
</div>

<style define:vars={{ heroBg: heroBgUrl }}>
  /* ----------------------------------------------------------------------
     Hero.

     LAYOUT (règle fondamentale) : le hero est une colonne flex.
       [marque → titre → sous-titre]  centrés (le masthead flex:1 absorbe
                                       l'espace libre au-dessus de l'image)
       [image équipe]                 en bas
     L'image suivant le texte dans le flux, elle ne peut JAMAIS remonter
     au-dessus du sous-titre ; au pire elle est rognée par le bas
     (overflow: hidden).

     ANIMATION : .hero-stage (haut) pilote une progression de scroll p∈[0,1]
     pendant que .hero reste sticky. Une unique boucle rAF (voir <script>)
     écrit des variables CSS ; toute la mise en mouvement est ci-dessous.
     ---------------------------------------------------------------------- */
  .hero-stage {
    position: relative;
    /* 1 écran épinglé + 0,6 écran de scroll qui joue l'animation : plus le
       2e nombre est petit, plus la section suivante apparaît tôt. */
    height: 160vh;
    background: #fafaf8;
  }

  .hero {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    background: #fafaf8;

    display: flex;
    flex-direction: column;
    align-items: center;

    /* Dégage le header fixe en haut. */
    padding-top: clamp(5.5rem, 11vh, 9rem);

    /* Chevauchement autorisé entre le haut de l'image et le bas du
       sous-titre (négatif = l'image frôle / mord légèrement le texte). */
    --team-overlap: 0rem;

    /* Variables pilotées par le scroll + la souris (valeurs au repos). */
    --bg-scale: 1;
    --bg-x: 0px;
    --bg-y: 0px;
    --team-scale: 1;
    --team-blur: 0px;
    --team-opacity: 1;
    --team-x: 0px;
    --team-y: 0px;
    --masthead-y: 0px;
    --wash: 0;
  }

  /* Fond : la salle vide, plein cadre, derrière tout le reste. Zoom léger au
     scroll + parallaxe souris inverse (profondeur). */
  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: var(--heroBg);
    background-size: cover;
    background-position: center;
    transform: translate(var(--bg-x), var(--bg-y)) scale(var(--bg-scale));
    transform-origin: 50% 45%;
    will-change: transform;
    z-index: 0;
  }

  /* Voile blanc : monte en opacité en fin de scroll pour fondre le fond vers
     la couleur de page avant la section suivante. Il a lieu DERRIÈRE le texte
     (z-index 1, juste au-dessus du fond) : le nom, le titre et la description
     restent donc visibles par-dessus la fondue. */
  .hero__wash {
    position: absolute;
    inset: 0;
    background: #fafaf8;
    opacity: var(--wash);
    pointer-events: none;
    z-index: 1;
  }

  /* Bloc texte : centré, largeur proportionnelle plafonnée. */
  .hero__masthead {
    position: relative;
    z-index: 2;
    /* Occupe tout l'espace libre au-dessus de l'image (grow), sans jamais se
       compresser (shrink: 0 → texte ni écrasé ni rogné), et y centre le texte
       verticalement : le texte reste donc centré entre le header et le haut
       de l'image, quel que soit l'espace disponible. */
    flex: 1 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(1100px, 92vw);
    text-align: center;
    /* Au scroll : léger glissement vers le haut. Le texte ne s'efface PAS — il
       reste lisible par-dessus la fondue blanche jusqu'au bout. */
    transform: translateY(var(--masthead-y));
    will-change: transform;
  }

  .hero__brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    margin: 0 auto clamp(1.5rem, 3vw, 2.5rem);
    color: rgba(0, 0, 0, 0.82);
    /* Même voile blanc que le titre — drop-shadow pour couvrir à la fois le
       logo (SVG) et le nom (texte). */
    filter:
      drop-shadow(0 0 10px rgba(250, 250, 248, 0.6))
      drop-shadow(0 0 22px rgba(250, 250, 248, 0.45));
  }

  .hero__brand-logo {
    display: inline-flex;
    align-items: center;
    height: clamp(26px, 2.4vw, 40px);
  }

  .hero__brand-logo :global(svg) {
    height: 100%;
    width: auto;
    display: block;
  }

  .hero__brand-logo :global(svg path) {
    fill: currentColor;
  }

  .hero__brand-name {
    font-family: "Quicksand", system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(1rem, 1.2vw, 1.4rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  /* Titre — l'élément le plus important : la plus grosse échelle, et il
     continue de grandir sur les très grands écrans. */
  .hero__title {
    margin: 0;
    font-family: "Libre Baskerville", Georgia, serif;
    font-weight: 700;
    font-size: clamp(2.1rem, 4vw, 4.5rem);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: rgba(0, 0, 0, 0.82);
    text-wrap: balance;
    /* Voile blanc diffus derrière le texte : invisible sur les zones claires
       de l'image, il rétablit le contraste quand le titre noir passe sur une
       zone sombre du fond. */
    text-shadow:
      0 0 14px rgba(250, 250, 248, 0.65),
      0 0 32px rgba(250, 250, 248, 0.5),
      0 0 64px rgba(250, 250, 248, 0.4);
  }

  .hero__subtitle {
    margin: clamp(1.1rem, 2vw, 1.75rem) auto 0;
    max-width: min(54rem, 90vw);
    font-family: "Quicksand", system-ui, sans-serif;
    font-weight: 500;
    /* Plancher lisible (≈14px), grandit proportionnellement. */
    font-size: clamp(0.875rem, 1vw, 1.25rem);
    letter-spacing: 0.16em;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.75);
    text-transform: uppercase;
    text-wrap: balance;
    /* Même voile blanc, plus léger (texte plus petit). */
    text-shadow:
      0 0 10px rgba(250, 250, 248, 0.6),
      0 0 24px rgba(250, 250, 248, 0.45);
  }

  /* Image équipe — en bas du viewport, largeur proportionnelle. Le masthead
     (flex:1) absorbe l'espace libre au-dessus ; l'image ne remonte sur le
     texte que si l'écran est trop court, et dans ce cas elle est rognée par
     le bas (jamais par le haut, le texte restant prioritaire dans le flux). */
  .hero__team {
    position: relative;
    /* Au premier plan (z-index 3) : au scroll, l'équipe grossit et passe
       DEVANT le texte avant de se dissoudre. */
    z-index: 3;
    /* Plus de margin-top:auto : c'est le masthead (flex:1) qui absorbe
       désormais l'espace libre. L'image reste collée au bas du viewport. */
    margin-bottom: var(--team-overlap);
    /* La table déborde volontairement le viewport (~135% de large) : les
       bords sont rognés (~13 % par côté) par overflow:hidden, ce qui maximise
       la taille de la table tant qu'on n'a pas atteint le plafond. Plafond à
       900px : au-delà la table garde cette largeur et cesse de grandir. */
    width: min(135vw, 900px);
    height: auto;
    flex-shrink: 0; /* ne pas écraser l'image quand la hauteur manque */
    object-fit: contain;
    object-position: bottom center;
    pointer-events: none;
    user-select: none;
    /* Au scroll : l'équipe grossit, se floute et s'efface pour se dissoudre
       dans la salle vide du fond. + parallaxe souris. */
    transform: translate(var(--team-x), var(--team-y)) scale(var(--team-scale));
    transform-origin: 50% 58%;
    filter: blur(var(--team-blur));
    opacity: var(--team-opacity);
    will-change: transform, filter, opacity;
  }

  /* En mode mobile, le Header se réduit au logo + nom (même breakpoint que
     son passage en burger) : la marque du Hero ferait doublon, on la masque. */
  @media (max-width: 900px) {
    .hero__brand {
      display: none;
    }
    /* Sur mobile, on rogne encore ~10 % de plus sur les côtés (débordement
       porté à 150vw) pour agrandir d'autant la table. */
    .hero__team {
      width: min(150vw, 900px);
    }
  }

  /* Mouvement réduit : pas de scroll-télling ni de parallaxe. Le stage se
     réduit à un écran, le hero redevient statique. */
  @media (prefers-reduced-motion: reduce) {
    .hero-stage {
      height: 100svh;
    }
    .hero {
      position: relative;
    }
    .hero__bg {
      transform: none;
    }
    .hero__team {
      transform: none;
      filter: none;
      opacity: 1;
    }
    .hero__masthead {
      transform: none;
    }
    .hero__wash {
      opacity: 0;
    }
  }
</style>

<script>
  const stage = document.getElementById("hero-stage");
  const hero = document.getElementById("hero");
  if (stage && hero) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const canHover = !window.matchMedia("(hover: none)").matches;

    const clamp = (v: number, lo: number, hi: number) =>
      v < lo ? lo : v > hi ? hi : v;
    // Interpole v (∈[a,b]) vers [c,d], borné.
    const remap = (v: number, a: number, b: number, c: number, d: number) =>
      c + (d - c) * clamp((v - a) / (b - a), 0, 1);

    let p = 0; // progression de scroll 0 → 1
    let mx = 0, my = 0; // cible souris (-1 → 1)
    let cx = 0, cy = 0; // position souris lissée
    let raf: number | null = null;
    let dirty = false;

    const schedule = () => {
      if (raf == null) raf = requestAnimationFrame(render);
    };

    const readScroll = () => {
      const total = stage.offsetHeight - window.innerHeight;
      p = total > 0 ? clamp(-stage.getBoundingClientRect().top / total, 0, 1) : 0;
    };

    function render() {
      raf = null;
      if (canHover) {
        cx += (mx - cx) * 0.08;
        cy += (my - cy) * 0.08;
      }

      // La parallaxe s'estompe dès qu'on scrolle (l'effet de scroll prend le relais).
      const par = clamp(1 - p * 2, 0, 1);
      const s = hero!.style;
      s.setProperty("--team-x", (cx * 8 * par).toFixed(2) + "px");
      s.setProperty("--team-y", (cy * 5 * par).toFixed(2) + "px");
      s.setProperty("--bg-x", (-cx * 4 * par).toFixed(2) + "px");
      s.setProperty("--bg-y", (-cy * 3 * par).toFixed(2) + "px");

      s.setProperty("--bg-scale", remap(p, 0, 1, 1, 1.8).toFixed(4));
      s.setProperty("--team-scale", remap(p, 0, 0.7, 1, 3.2).toFixed(4));
      s.setProperty("--team-blur", remap(p, 0.1, 0.6, 0, 22).toFixed(2) + "px");
      s.setProperty("--team-opacity", remap(p, 0.3, 0.65, 1, 0).toFixed(3));
      s.setProperty("--masthead-y", remap(p, 0.4, 1, 0, -36).toFixed(1) + "px");
      s.setProperty("--wash", remap(p, 0.6, 0.95, 0, 1).toFixed(3));

      const settling =
        canHover && (Math.abs(mx - cx) > 0.001 || Math.abs(my - cy) > 0.001);
      if (settling || dirty) {
        dirty = false;
        schedule();
      }
    }

    if (!reduce) {
      window.addEventListener(
        "scroll",
        () => {
          readScroll();
          dirty = true;
          schedule();
        },
        { passive: true },
      );
      window.addEventListener("resize", () => {
        readScroll();
        dirty = true;
        schedule();
      });
      if (canHover) {
        hero.addEventListener("mousemove", (e: MouseEvent) => {
          const r = hero!.getBoundingClientRect();
          mx = clamp(((e.clientX - r.left) / r.width) * 2 - 1, -1, 1);
          my = clamp(((e.clientY - r.top) / r.height) * 2 - 1, -1, 1);
          schedule();
        });
        hero.addEventListener("mouseleave", () => {
          mx = 0;
          my = 0;
          schedule();
        });
      }
      readScroll();
      dirty = true;
      schedule();
    }
  }
</script>
