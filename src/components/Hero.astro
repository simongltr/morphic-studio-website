---
import Logo from "./Logo.astro";
import { withBase } from "../utils/url";

const heroBgUrl = `url(${withBase("/hero-background.webp")})`;
---

<section class="hero" id="hero">
  <div class="hero__bg"></div>
  <div class="hero__masthead">
    <div class="hero__brand" aria-label="Morphic Studio">
      <span class="hero__brand-logo">
        <Logo />
      </span>
      <span class="hero__brand-name">MORPHIC STUDIO</span>
    </div>
    <h1 class="hero__title">
      Le studio web qui modernise le digital des TPE et PME.
    </h1>
    <p class="hero__subtitle">
      Sites web, boutiques en ligne et outils métier pour lancer un projet,
      améliorer un process ou remplacer un outil interne devenu limitant par
      une solution sur mesure.
    </p>
  </div>
  <img
    class="hero__team"
    src={withBase("/hero-team.webp")}
    alt=""
  />
</section>

<style define:vars={{ heroBg: heroBgUrl }}>
  /* ----------------------------------------------------------------------
     Hero — base statique (aucune animation pour l'instant).

     Règle de layout fondamentale : le hero est une colonne flex.
       [marque → titre → sous-titre]  poussés en haut
       [image équipe]                 poussée en bas (margin-top: auto)
     L'image suivant le texte dans le flux, elle ne peut JAMAIS remonter
     au-dessus du sous-titre ; au pire elle est rognée par le bas
     (overflow: hidden). Le chevauchement autorisé = une seule variable.
     ---------------------------------------------------------------------- */
  .hero {
    position: relative;
    /* Hauteur fixée à un écran : la table peut déborder sous la ligne de
       flottaison, elle est alors rognée par le bas via overflow:hidden. */
    height: 100svh;
    overflow: hidden;
    background: #fafaf8;

    display: flex;
    flex-direction: column;
    align-items: center;

    /* Dégage le header fixe en haut. */
    padding-top: clamp(5.5rem, 11vh, 9rem);

    /* Chevauchement autorisé entre le haut de l'image et le bas du
       sous-titre (négatif = l'image frôle / mord légèrement le texte). */
    --team-overlap: 0rem;
  }

  /* Fond : la salle vide, plein cadre, derrière tout le reste. */
  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: var(--heroBg);
    background-size: cover;
    background-position: center;
    z-index: 0;
  }

  /* Bloc texte : centré, largeur proportionnelle plafonnée. */
  .hero__masthead {
    position: relative;
    z-index: 2;
    /* Occupe tout l'espace libre au-dessus de l'image (grow), sans jamais se
       compresser (shrink: 0 → texte ni écrasé ni rogné), et y centre le texte
       verticalement : le texte reste donc centré entre le header et le haut
       de l'image, quel que soit l'espace disponible. */
    flex: 1 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(1100px, 92vw);
    text-align: center;
  }

  .hero__brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    margin: 0 auto clamp(1.5rem, 3vw, 2.5rem);
    color: rgba(0, 0, 0, 0.82);
    /* Même voile blanc que le titre — drop-shadow pour couvrir à la fois le
       logo (SVG) et le nom (texte). */
    filter:
      drop-shadow(0 0 10px rgba(250, 250, 248, 0.6))
      drop-shadow(0 0 22px rgba(250, 250, 248, 0.45));
  }

  .hero__brand-logo {
    display: inline-flex;
    align-items: center;
    height: clamp(26px, 2.4vw, 40px);
  }

  .hero__brand-logo :global(svg) {
    height: 100%;
    width: auto;
    display: block;
  }

  .hero__brand-logo :global(svg path) {
    fill: currentColor;
  }

  .hero__brand-name {
    font-family: "Quicksand", system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(1rem, 1.2vw, 1.4rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  /* Titre — l'élément le plus important : la plus grosse échelle, et il
     continue de grandir sur les très grands écrans. */
  .hero__title {
    margin: 0;
    font-family: "Libre Baskerville", Georgia, serif;
    font-weight: 700;
    font-size: clamp(2.1rem, 4vw, 4.5rem);
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: rgba(0, 0, 0, 0.82);
    text-wrap: balance;
    /* Voile blanc diffus derrière le texte : invisible sur les zones claires
       de l'image, il rétablit le contraste quand le titre noir passe sur une
       zone sombre du fond. */
    text-shadow:
      0 0 14px rgba(250, 250, 248, 0.65),
      0 0 32px rgba(250, 250, 248, 0.5),
      0 0 64px rgba(250, 250, 248, 0.4);
  }

  .hero__subtitle {
    margin: clamp(1.1rem, 2vw, 1.75rem) auto 0;
    max-width: min(54rem, 90vw);
    font-family: "Quicksand", system-ui, sans-serif;
    font-weight: 500;
    /* Plancher lisible (≈14px), grandit proportionnellement. */
    font-size: clamp(0.875rem, 1vw, 1.25rem);
    letter-spacing: 0.16em;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.75);
    text-transform: uppercase;
    text-wrap: balance;
    /* Même voile blanc, plus léger (texte plus petit). */
    text-shadow:
      0 0 10px rgba(250, 250, 248, 0.6),
      0 0 24px rgba(250, 250, 248, 0.45);
  }

  /* Image équipe — en bas du viewport, largeur proportionnelle. Le masthead
     (flex:1) absorbe l'espace libre au-dessus ; l'image ne remonte sur le
     texte que si l'écran est trop court, et dans ce cas elle est rognée par
     le bas (jamais par le haut, le texte restant prioritaire dans le flux). */
  .hero__team {
    position: relative;
    z-index: 1;
    /* Plus de margin-top:auto : c'est le masthead (flex:1) qui absorbe
       désormais l'espace libre. L'image reste collée au bas du viewport. */
    margin-bottom: var(--team-overlap);
    /* La table déborde volontairement le viewport (~135% de large) : les
       bords sont rognés (~13 % par côté) par overflow:hidden, ce qui maximise
       la taille de la table tant qu'on n'a pas atteint le plafond. Plafond à
       900px : au-delà la table garde cette largeur et cesse de grandir. */
    width: min(135vw, 900px);
    height: auto;
    flex-shrink: 0; /* ne pas écraser l'image quand la hauteur manque */
    object-fit: contain;
    object-position: bottom center;
    pointer-events: none;
    user-select: none;
  }

  /* En mode mobile, le Header se réduit au logo + nom (même breakpoint que
     son passage en burger) : la marque du Hero ferait doublon, on la masque. */
  @media (max-width: 900px) {
    .hero__brand {
      display: none;
    }
    /* Sur mobile, on rogne encore ~10 % de plus sur les côtés (débordement
       porté à 150vw) pour agrandir d'autant la table. */
    .hero__team {
      width: min(150vw, 900px);
    }
  }
</style>
