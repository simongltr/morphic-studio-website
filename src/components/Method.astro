---
import { Icon } from "astro-icon/components";

const steps = [
  {
    icon: "lucide:message-circle",
    title: "Cadrage",
    body: "On comprend votre projet, on précise le périmètre, on chiffre. Vous repartez avec un devis ferme et un planning.",
    duration: "≈ 1 semaine",
  },
  {
    icon: "lucide:pen-tool",
    title: "Design",
    body: "On dessine l'architecture, les écrans, les interactions. Vous validez chaque étape avant qu'on touche au code.",
    duration: "2 à 3 semaines",
  },
  {
    icon: "lucide:code-2",
    title: "Développement",
    body: "On construit, on teste, on intègre vos contenus. Une démo accessible à tout moment, mise à jour en continu.",
    duration: "3 à 6 semaines",
  },
  {
    icon: "lucide:rocket",
    title: "Mise en ligne",
    body: "On déploie, on forme votre équipe, on vous remet les clés : code, accès, fichiers. 30 jours de suivi inclus.",
    duration: "1 semaine + suivi",
  },
];
---

<section id="methode" class="section method">
  <p class="section__eyebrow">Méthode</p>
  <h2 class="section__title">Comment on travaille.</h2>
  <p class="section__body">
    Quatre étapes claires, des livrables à chaque palier, un délai ferme dès le
    cadrage. Pas de dérive silencieuse, pas de surprise à la facture finale.
  </p>

  <ol class="method__steps method__steps--icons">
    {
      steps.map((step) => (
        <li class="method__step">
          <div class="method__node" aria-hidden="true">
            <Icon name={step.icon} />
          </div>
          <div class="method__content">
            <h3 class="method__title">{step.title}</h3>
            <p class="method__body">{step.body}</p>
            <p class="method__duration">{step.duration}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .method__steps {
    /* One single stroke value drives BOTH the line and the circle borders,
       so they can never read as different weights. */
    --stroke: 2px;
    /* Line a touch thinner than the ring border to optically match the
       curved stroke of the circles */
    --line-stroke: 1.5px;
    /* Single ink value for line AND rings so they read identical */
    --stroke-color: rgba(0, 0, 0, 0.85);
    --node-size: 48px;
    --node-half: calc(var(--node-size) / 2);
    --method-gap: clamp(1.5rem, 3vw, 2.5rem);

    list-style: none;
    margin: clamp(2.5rem, 5vh, 4rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: var(--method-gap);
    position: relative;
  }

  .method__step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Connector segment from this node to the next one */
  .method__step::after {
    content: "";
    position: absolute;
    top: var(--node-half);
    left: var(--node-half);
    width: calc(100% + var(--method-gap));
    height: var(--line-stroke);
    background: var(--stroke-color);
    transform: translateY(-50%);
    z-index: 0;
  }
  .method__step:last-child::after {
    display: none;
  }

  .method__node {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: var(--node-size);
    height: var(--node-size);
    display: flex;
    align-items: center;
    justify-content: center;
    border: var(--stroke) solid var(--stroke-color);
    border-radius: 50%;
    background: #fafaf8;
    margin-bottom: 1.5rem;
  }

  /* Icon living inside the ring (version A) */
  .method__node :global(svg) {
    width: 20px;
    height: 20px;
    stroke-width: 1.5;
    color: rgba(0, 0, 0, 0.85);
  }

  .method__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .method__title {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.3;
    margin: 0 0 0.5rem;
    color: rgba(0, 0, 0, 0.92);
  }
  .method__body {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(0, 0, 0, 0.6);
    margin: 0 0 1rem;
    flex-grow: 1;
  }
  .method__duration {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: rgba(0, 0, 0, 0.45);
    margin: 0;
  }

  /* Vertical timeline — kept continuous on tablet & mobile */
  @media (max-width: 900px) {
    .method__steps {
      display: flex;
      flex-direction: column;
      row-gap: var(--method-gap);
    }
    .method__step {
      flex-direction: row;
      align-items: flex-start;
      column-gap: 1.25rem;
    }
    .method__node {
      margin-bottom: 0;
    }
    /* Connector now runs vertically down to the next node */
    .method__step::after {
      top: var(--node-half);
      left: var(--node-half);
      width: var(--line-stroke);
      height: calc(100% + var(--method-gap));
      transform: translateX(-50%);
    }
    .method__content {
      padding-top: 0.1rem;
    }
  }
</style>
