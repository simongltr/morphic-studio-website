---
import { Icon } from "astro-icon/components";

const standards = [
  {
    icon: "lucide:search",
    title: "SEO de base",
    text: "Structure sémantique, métadonnées, sitemap et indexation propre dès la mise en ligne.",
  },
  {
    icon: "lucide:sparkles",
    title: "SEO IA",
    text: "Pages lisibles par ChatGPT, Perplexity et Google AI Overviews, pas seulement par Google.",
  },
  {
    icon: "lucide:gauge",
    title: "Performance",
    text: "Core Web Vitals dans le vert. Chargement rapide sur mobile comme sur fibre.",
  },
  {
    icon: "lucide:accessibility",
    title: "Accessibilité",
    text: "Contrastes, focus clavier, hiérarchie correcte. WCAG AA sur les fondamentaux.",
  },
  {
    icon: "lucide:monitor-smartphone",
    title: "Responsive",
    text: "Testé sur mobile, tablette et desktop. Pas de version dégradée pour personne.",
  },
];
---

<section class="section always-included">
  <div class="ai-intro">
    <p class="section__eyebrow">Toujours inclus</p>
    <h2 class="section__title">Cinq standards techniques sur chaque livraison.</h2>
    <p class="ai-lead">
      Quelle que soit l'offre choisie au-dessus, ces fondations ne sont jamais une option ni un supplément. En 2026, livrer un site sans ça, c'est livrer un site cassé.
    </p>
  </div>
  <ul class="ai-grid">
    {
      standards.map((s) => (
        <li class="ai-card">
          <span class="ai-card__icon" aria-hidden="true">
            <Icon name={s.icon} />
          </span>
          <span class="ai-card__title">{s.title}</span>
          <span class="ai-card__text">{s.text}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .always-included {
    padding-top: clamp(2rem, 5vh, 3.5rem);
    padding-bottom: clamp(2rem, 5vh, 3.5rem);
  }
  .ai-intro {
    max-width: 720px;
    margin: 0 0 clamp(1.5rem, 3vw, 2.5rem);
  }
  .ai-lead {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.6);
    max-width: 60ch;
  }
  .ai-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
  }
  .ai-card {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 0.55rem;
    min-width: 0;
    padding: 1rem;
    border-radius: 10px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.86), rgba(248, 247, 243, 0.94)),
      #f5f2ea;
    border: 1px solid rgba(0, 0, 0, 0.07);
  }
  .ai-card__icon {
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.06);
    color: rgba(0, 0, 0, 0.82);
  }
  .ai-card__icon [data-icon] {
    width: 19px;
    height: 19px;
  }
  .ai-card__title {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-size: 0.95rem;
    line-height: 1.2;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.88);
  }
  .ai-card__text {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.82rem;
    line-height: 1.45;
    color: rgba(0, 0, 0, 0.6);
  }

  @media (max-width: 1100px) {
    .ai-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (max-width: 720px) {
    .ai-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 480px) {
    .ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
