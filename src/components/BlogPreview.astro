---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { withBase } from "../utils/url";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<section class="section blog-preview">
  <p class="section__eyebrow">Blog</p>
  <h2 class="section__title">Derniers articles.</h2>

  <ul class="blog-preview__grid">
    {
      posts.map((post) => (
        <li class="blog-preview__item">
          <a class="blog-preview__link" href={withBase(`/blog/${post.id}/`)}>
            <div class="blog-preview__media">
              <img
                src={withBase(post.data.heroImage)}
                alt={post.data.heroAlt}
                loading="lazy"
              />
            </div>
            <p class="blog-preview__meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {dateFmt.format(post.data.pubDate)}
              </time>
            </p>
            <h3 class="blog-preview__title">{post.data.title}</h3>
            <p class="blog-preview__desc">{post.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>

  <div class="blog-preview__cta">
    <a class="blog-preview__more" href={withBase("/blog/")}>
      <span>Voir tous les articles</span>
      <Icon name="lucide:arrow-right" />
    </a>
  </div>
</section>

<style>
  .blog-preview__grid {
    list-style: none;
    margin: 0 0 2.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .blog-preview__item {
    margin: 0;
  }
  .blog-preview__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .blog-preview__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    margin-bottom: 1.25rem;
    background: rgba(0, 0, 0, 0.03);
  }
  .blog-preview__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }
  .blog-preview__link:hover .blog-preview__media img {
    transform: scale(1.03);
  }
  .blog-preview__meta {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: rgba(0, 0, 0, 0.5);
    margin: 0 0 0.5rem;
    text-transform: lowercase;
  }
  .blog-preview__title {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: clamp(1.125rem, 1.4vw, 1.3125rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
    color: rgba(0, 0, 0, 0.92);
  }
  .blog-preview__desc {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.62);
    margin: 0;
  }

  .blog-preview__cta {
    display: flex;
    justify-content: flex-start;
  }
  .blog-preview__more {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 999px;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.88);
    text-decoration: none;
    transition: background 200ms ease, border-color 200ms ease;
  }
  .blog-preview__more:hover {
    background: rgba(0, 0, 0, 0.04);
    border-color: rgba(0, 0, 0, 0.25);
  }
  .blog-preview__more :global(svg) {
    width: 16px;
    height: 16px;
    transition: transform 200ms ease;
  }
  .blog-preview__more:hover :global(svg) {
    transform: translateX(2px);
  }

  @media (max-width: 900px) {
    .blog-preview__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .blog-preview__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
