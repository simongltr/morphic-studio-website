---
import { Icon } from "astro-icon/components";

const items = [
  {
    icon: "lucide:tag",
    q: "Comment proposez-vous des prix aussi compétitifs ?",
    a: "Nous combinons expertise humaine et outils modernes qui automatisent les tâches répétitives. Ce temps gagné, nous vous le rendons en délais plus courts et tarifs plus justes.",
  },
  {
    icon: "lucide:file-text",
    q: "Qu'est-ce qui est inclus dans le prix ?",
    a: "Cadrage, design responsive, développement, mise en ligne, formation, accès et fichiers. Ce qui n'est pas inclus par défaut est listé clairement au devis.",
  },
  {
    icon: "lucide:arrow-left-right",
    q: "Que se passe-t-il si le périmètre change ?",
    a: "Si une demande sort du cadre validé, nous vous proposons un avenant chiffré avant de l'engager. Pas de dérive silencieuse, pas de surprise sur la facture finale.",
  },
  {
    icon: "lucide:clock",
    q: "Combien de temps prend un projet ?",
    a: "Un site vitrine se livre en quelques semaines, une application en quelques semaines à quelques mois selon sa complexité. Délai ferme dès le cadrage.",
  },
  {
    icon: "lucide:code",
    q: "Sur quelles technologies travaillez-vous ?",
    a: "Astro, Next.js, React et TypeScript pour le web, React Native pour le mobile. Des technologies modernes et largement adoptées, faciles à reprendre par d'autres équipes.",
  },
  {
    icon: "lucide:key",
    q: "Suis-je propriétaire du site ou de l'application ?",
    a: "Oui. À la livraison, vous récupérez les accès, le code source et les fichiers prévus. Vous n'êtes jamais dépendant de nous par défaut.",
  },
];
---

<section class="section faq">
  <p class="section__eyebrow">FAQ</p>
  <h2 class="section__title">Questions fréquentes.</h2>
  <p class="section__body">
    Tout ce qu'il faut savoir sur nos offres et la facturation. Vous ne
    trouvez pas votre réponse ? <a href="#contact" class="faq__link"
      >écrivez-nous</a
    >.
  </p>

  <ul class="faq__grid">
    {
      items.map((item) => (
        <li class="faq__item">
          <span class="faq__icon" aria-hidden="true">
            <Icon name={item.icon} />
          </span>
          <h3 class="faq__q">{item.q}</h3>
          <p class="faq__a">{item.a}</p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .faq {
    padding-top: clamp(2rem, 4vh, 4rem);
  }
  .faq__link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .faq__link:hover {
    color: rgba(0, 0, 0, 0.9);
  }

  .faq__grid {
    list-style: none;
    margin: clamp(2.5rem, 5vh, 4rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 3vw, 2.5rem);
  }
  .faq__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .faq__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    color: rgba(0, 0, 0, 0.75);
    margin-bottom: 1.5rem;
  }
  .faq__icon :global(svg) {
    width: 20px;
    height: 20px;
    stroke-width: 1.5;
  }
  .faq__q {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.4;
    margin: 0 0 0.5rem;
    color: rgba(0, 0, 0, 0.92);
  }
  .faq__a {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(0, 0, 0, 0.6);
    margin: 0;
  }

  @media (max-width: 900px) {
    .faq__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .faq__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
