---
import { galleryColumns } from "../data/gallery-tiles";
---

<section class="section gallery">
  <div class="gallery-intro">
    <p class="section__eyebrow">Quelques aperçus</p>
    <h2 class="section__title">Un avant-goût de ce que nous fabriquons.</h2>
    <p class="gallery-intro__body">
      Une galerie de placeholders pour donner le ton — les vraies réalisations
      viendront s'installer ici, dans la même grille à trois colonnes.
    </p>
  </div>

  <div class="gallery-grid">
    {
      galleryColumns.map((col) => (
        <div class="gallery-col" style={`--y-range: ${col.yRange}%;`}>
          {col.tiles.map((tile) => (
            <div class="gallery-tile">
              <div
                class="gallery-tile__visual"
                style={`--tile-color: ${tile.color};`}
              />
            </div>
          ))}
        </div>
      ))
    }
  </div>
</section>

<style>
  .gallery-intro {
    max-width: 720px;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
  }
  .gallery-intro__body {
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(1rem, 1.15vw, 1.125rem);
    line-height: 1.65;
    color: rgba(0, 0, 0, 0.7);
    margin: 0;
    max-width: 56ch;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    view-timeline-name: --gallery-grid;
  }

  .gallery-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    will-change: transform;
  }
  /* Lift the column owning the hovered tile so its scaled preview paints
     above sibling columns. */
  .gallery-col:has(.gallery-tile:hover) {
    z-index: 10;
  }

  .gallery-tile {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
  }
  .gallery-tile__visual {
    position: absolute;
    inset: 0;
    background: var(--tile-color, #ddd);
    border-radius: 14px;
    box-shadow:
      0 22px 28px -16px rgba(0, 0, 0, 0.14),
      0 4px 8px -4px rgba(0, 0, 0, 0.05);
    transform-origin: center;
    transition:
      transform 380ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 380ms cubic-bezier(0.2, 0.8, 0.2, 1);
    /* Pointer events stay on the underlying tile so the preview never
       captures the cursor. Moving off the tile's footprint instantly
       releases the hover, even if the scaled preview is still under
       the mouse — letting the user scan from tile to tile. */
    pointer-events: none;
    z-index: 1;
  }
  .gallery-tile:hover .gallery-tile__visual {
    transform: scale(1.7);
    box-shadow:
      0 30px 60px -20px rgba(0, 0, 0, 0.28),
      0 10px 22px -10px rgba(0, 0, 0, 0.12);
    z-index: 5;
  }

  @keyframes gallery-col-parallax {
    from {
      transform: translateY(calc(var(--y-range, 0%) * -0.5));
    }
    to {
      transform: translateY(calc(var(--y-range, 0%) * 0.5));
    }
  }

  /* Scroll-driven animations — Chrome/Edge, Firefox 140+, Safari 26+. */
  @supports (animation-timeline: view()) {
    .gallery-col {
      animation: gallery-col-parallax linear both;
      animation-timeline: --gallery-grid;
      /* The full viewport crossing — no scroll-lock, the offset is
         visible as soon as the grid is on screen. */
      animation-range: cover 0% cover 100%;
    }
  }

  @media (max-width: 720px) {
    .gallery-grid {
      gap: 0.5rem;
    }
    .gallery-col {
      gap: 0.5rem;
    }
    .gallery-tile__visual {
      border-radius: 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-col {
      animation: none;
      transform: none;
    }
    .gallery-tile__visual,
    .gallery-tile:hover .gallery-tile__visual {
      transition: none;
      transform: none;
    }
  }
</style>
