---
import { caseStudies } from "../data/case-studies";
---

<section id="cas" class="case-pin-stage">
  <div class="case-pin" id="case-pin">
    <div class="case-pin__intro">
      <p class="section__eyebrow">Études de cas</p>
      <h2 class="section__title">Trois projets, trois échelles.</h2>
      <p class="case-pin__lede">
        Un artisan, une PME, une marketplace. Faites défiler — chaque cas
        apparaît horizontalement à mesure que vous scrollez.
      </p>
    </div>

    <div class="case-pin__viewport">
      <ol class="case-pin__track" id="case-pin-track">
        {
          caseStudies.map((cs, idx) => (
            <li
              class="case-pin__slide"
              style={`--accent: ${cs.accent};`}
            >
              <div class="case-pin__visual" aria-hidden="true">
                <span class="case-pin__visual-grain" />
                <span class="case-pin__visual-tag">{`0${idx + 1} / 0${caseStudies.length}`}</span>
                <span class="case-pin__visual-client">{cs.client}</span>
                <span class="case-pin__visual-sector">{cs.sector}</span>
              </div>

              <div class="case-pin__body">
                <p class="case-pin__tier">
                  <span class="case-pin__tier-name">{cs.tier}</span>
                  <span class="case-pin__tier-sep">·</span>
                  <span class="case-pin__tier-label">{cs.tierLabel}</span>
                </p>

                <dl class="case-pin__story">
                  <dt>Le besoin</dt>
                  <dd>{cs.problem}</dd>
                  <dt>Ce que nous avons livré</dt>
                  <dd>{cs.delivered}</dd>
                  <dt>Résultat</dt>
                  <dd class="case-pin__result">{cs.result}</dd>
                </dl>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="case-pin__progress" aria-hidden="true">
      {
        caseStudies.map((_, idx) => (
          <span class="case-pin__dot" data-idx={idx} />
        ))
      }
    </div>
  </div>
</section>

<style define:vars={{ slideCount: caseStudies.length }}>
  .case-pin-stage {
    position: relative;
    /* pin sizes to content (~760px); stage gives (slideCount-1) viewports of
       scroll-through, so the next section follows the progress bar with no
       trailing empty space. */
    height: calc(var(--slideCount) * 100vh);
    background: #fafaf8;
  }

  .case-pin {
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: clamp(5rem, 11vh, 7rem) 0 0;
  }

  .case-pin__intro {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 6vw, 6rem);
    flex: 0 0 auto;
  }
  .case-pin__lede {
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(0.95rem, 1.05vw, 1.05rem);
    line-height: 1.6;
    color: rgba(0, 0, 0, 0.6);
    margin: 0 0 clamp(2.5rem, 5vh, 4rem);
    max-width: 60ch;
  }

  .case-pin__viewport {
    flex: 0 0 auto;
    overflow: hidden;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 6vw, 6rem);
    height: clamp(380px, 48vh, 480px);
  }

  .case-pin__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    height: 100%;
    width: calc(100% * var(--slideCount));
    transform: translate3d(var(--pin-x, 0), 0, 0);
    will-change: transform;
  }

  .case-pin__slide {
    flex: 0 0 calc(100% / var(--slideCount));
    height: 100%;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
    padding-right: clamp(1.5rem, 4vw, 3rem);
  }

  .case-pin__visual {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 18px;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 30% 20%,
        color-mix(in srgb, var(--accent) 80%, #ffffff 20%),
        var(--accent) 60%,
        color-mix(in srgb, var(--accent) 70%, #000000 30%) 100%
      );
    color: #f4f1ea;
    isolation: isolate;
  }
  .case-pin__visual-grain {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.04) 0 1px,
        transparent 1px 22px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.04) 0 1px,
        transparent 1px 22px
      );
    mix-blend-mode: screen;
    pointer-events: none;
  }
  .case-pin__visual-tag {
    position: absolute;
    top: 1.25rem;
    left: 1.5rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }
  .case-pin__visual-client {
    position: absolute;
    left: 1.5rem;
    bottom: 2.75rem;
    right: 1.5rem;
    font-family: "Libre Baskerville", Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    line-height: 1.15;
  }
  .case-pin__visual-sector {
    position: absolute;
    left: 1.5rem;
    bottom: 1.25rem;
    right: 1.5rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.875rem;
    opacity: 0.75;
  }

  .case-pin__body {
    min-width: 0;
  }
  .case-pin__tier {
    margin: 0 0 1.25rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: rgba(0, 0, 0, 0.55);
    display: inline-flex;
    gap: 0.5rem;
  }
  .case-pin__tier-name {
    color: rgba(0, 0, 0, 0.85);
    font-weight: 500;
  }
  .case-pin__tier-sep {
    opacity: 0.4;
  }
  .case-pin__story {
    margin: 0 0 1.5rem;
    padding: 1.25rem 0 0;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }
  .case-pin__story dt {
    margin-top: 1rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
    margin-bottom: 0.4rem;
  }
  .case-pin__story dd {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.78);
  }
  .case-pin__result {
    color: rgba(0, 0, 0, 0.88) !important;
    font-style: italic;
  }

  .case-pin__progress {
    flex: 0 0 auto;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    padding: 1.25rem 0 1.5rem;
  }
  .case-pin__dot {
    width: 28px;
    height: 2px;
    background: rgba(0, 0, 0, 0.18);
    transition: background 200ms ease;
  }
  .case-pin__dot[data-active="true"] {
    background: rgba(0, 0, 0, 0.85);
  }

  @media (max-width: 820px) {
    .case-pin-stage {
      height: auto;
    }
    .case-pin {
      position: relative;
      height: auto;
      overflow: visible;
    }
    .case-pin__viewport {
      overflow: visible;
    }
    .case-pin__track {
      flex-direction: column;
      width: 100%;
      transform: none;
      gap: 2.5rem;
    }
    .case-pin__slide {
      flex: 0 0 auto;
      grid-template-columns: 1fr;
      padding-right: 0;
    }
    .case-pin__progress {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-pin-stage {
      height: auto;
    }
    .case-pin {
      position: relative;
      height: auto;
      overflow: visible;
    }
    .case-pin__viewport {
      overflow: visible;
    }
    .case-pin__track {
      flex-direction: column;
      width: 100%;
      transform: none;
      gap: 2.5rem;
    }
    .case-pin__slide {
      flex: 0 0 auto;
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const stage = document.querySelector<HTMLElement>(".case-pin-stage");
  const pin = document.getElementById("case-pin");
  const track = document.getElementById("case-pin-track");
  if (stage && pin && track) {
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isMobile = window.matchMedia("(max-width: 820px)").matches;

    if (!reducedMotion && !isMobile) {
      const dots = Array.from(
        pin.querySelectorAll<HTMLElement>(".case-pin__dot"),
      );
      const slideCount = dots.length;
      let raf: number | null = null;

      const clamp = (v: number, lo: number, hi: number) =>
        v < lo ? lo : v > hi ? hi : v;

      const render = () => {
        raf = null;
        const rect = stage.getBoundingClientRect();
        const total = stage.offsetHeight - window.innerHeight;
        const p = total > 0 ? clamp(-rect.top / total, 0, 1) : 0;
        const travel = (slideCount - 1) / slideCount; // viewport-relative
        const tx = -p * travel * 100;
        track.style.setProperty("--pin-x", tx.toFixed(3) + "%");

        const active = Math.round(p * (slideCount - 1));
        dots.forEach((dot, i) =>
          dot.setAttribute("data-active", i === active ? "true" : "false"),
        );
      };

      const schedule = () => {
        if (raf == null) raf = requestAnimationFrame(render);
      };

      window.addEventListener("scroll", schedule, { passive: true });
      window.addEventListener("resize", schedule);
      schedule();
    } else {
      const dots = pin.querySelectorAll<HTMLElement>(".case-pin__dot");
      dots.forEach((d) => d.setAttribute("data-active", "true"));
    }
  }
</script>
