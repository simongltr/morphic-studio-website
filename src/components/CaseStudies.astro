---
import { caseStudies } from "../data/case-studies";
---

<section id="cas" class="section cs-editorial">
  <div class="cs-editorial__intro">
    <p class="section__eyebrow">Études de cas</p>
    <h2 class="section__title">Trois projets, trois échelles.</h2>
    <p class="cs-editorial__lede">
      Un artisan, une PME, une marketplace. Trois échelles différentes,
      une même méthode.
    </p>
  </div>

  <ol class="cs-editorial__list">
    {
      caseStudies.map((cs, idx) => (
        <li class="cs-editorial__row" style={`--accent: ${cs.accent};`}>
          <div class="cs-editorial__visual" aria-hidden="true">
            <span class="cs-editorial__visual-grain" />
            <span class="cs-editorial__visual-tag">{`0${idx + 1} / 0${caseStudies.length}`}</span>
            <span class="cs-editorial__visual-client">{cs.client}</span>
            <span class="cs-editorial__visual-sector">{cs.sector}</span>
          </div>

          <div class="cs-editorial__body">
            <p class="cs-editorial__tier">
              <span class="cs-editorial__tier-name">{cs.tier}</span>
              <span class="cs-editorial__tier-sep">·</span>
              <span class="cs-editorial__tier-label">{cs.tierLabel}</span>
            </p>

            <dl class="cs-editorial__story">
              <dt>Le besoin</dt>
              <dd>{cs.problem}</dd>
              <dt>Ce que nous avons livré</dt>
              <dd>{cs.delivered}</dd>
              <dt>Résultat</dt>
              <dd class="cs-editorial__result">{cs.result}</dd>
            </dl>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .cs-editorial__intro {
    max-width: 720px;
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
  }
  .cs-editorial__lede {
    margin: 0.5rem 0 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(0.95rem, 1.05vw, 1.05rem);
    line-height: 1.6;
    color: rgba(0, 0, 0, 0.6);
    max-width: 60ch;
  }
  .cs-editorial__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 7vw, 5rem);
  }
  .cs-editorial__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  .cs-editorial__row:nth-child(even) .cs-editorial__visual {
    order: 2;
  }
  .cs-editorial__visual {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 18px;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 30% 20%,
        color-mix(in srgb, var(--accent) 80%, #ffffff 20%),
        var(--accent) 60%,
        color-mix(in srgb, var(--accent) 70%, #000000 30%) 100%
      );
    color: #f4f1ea;
    isolation: isolate;
  }
  .cs-editorial__visual-grain {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.04) 0 1px,
        transparent 1px 22px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.04) 0 1px,
        transparent 1px 22px
      );
    mix-blend-mode: screen;
    pointer-events: none;
  }
  .cs-editorial__visual-tag {
    position: absolute;
    top: 1.25rem;
    left: 1.5rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }
  .cs-editorial__visual-client {
    position: absolute;
    left: 1.5rem;
    bottom: 2.75rem;
    right: 1.5rem;
    font-family: "Libre Baskerville", Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 2.25rem);
    line-height: 1.15;
  }
  .cs-editorial__visual-sector {
    position: absolute;
    left: 1.5rem;
    bottom: 1.25rem;
    right: 1.5rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.875rem;
    opacity: 0.75;
  }
  .cs-editorial__tier {
    margin: 0 0 1.25rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: rgba(0, 0, 0, 0.55);
    display: inline-flex;
    gap: 0.5rem;
  }
  .cs-editorial__tier-name {
    color: rgba(0, 0, 0, 0.85);
    font-weight: 500;
  }
  .cs-editorial__tier-sep {
    opacity: 0.4;
  }
  .cs-editorial__story {
    margin: 0;
    padding: 1.25rem 0 0;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }
  .cs-editorial__story dt {
    margin-top: 1rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
    margin-bottom: 0.4rem;
  }
  .cs-editorial__story dd {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.78);
  }
  .cs-editorial__result {
    color: rgba(0, 0, 0, 0.88) !important;
    font-style: italic;
  }

  @media (max-width: 820px) {
    .cs-editorial__row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .cs-editorial__row:nth-child(even) .cs-editorial__visual {
      order: 0;
    }
  }
</style>
