---
import { Icon } from "astro-icon/components";
import { pricingPlans } from "../data/pricing-plans";
---

<section id="tarifs" class="section pricing">
  <p class="section__eyebrow">Tarifs</p>
  <h2 class="section__title">Quatre forfaits qui couvrent toutes les catégories.</h2>
  <p class="section__body">
    À chaque type de projet correspond un palier. Précis quand vous savez déjà
    ce que vous voulez, sur devis quand on doit cadrer ensemble.
  </p>

  <ul class="pricing__grid">
    {
      pricingPlans.map((plan) => (
        <li
          class:list={[
            "pricing__card",
            { "pricing__card--popular": plan.popular },
          ]}
        >
          {plan.popular && (
            <span class="pricing__badge">
              <Icon name="lucide:sparkles" />
              <span>Le plus demandé</span>
            </span>
          )}

          <header class="pricing__header">
            <h3 class="pricing__name">{plan.name}</h3>
            <p class="pricing__tagline">{plan.tagline}</p>
          </header>

          <div class="pricing__price-block">
            <p class="pricing__price">
              <span class="pricing__amount">{plan.price}</span>
              {plan.priceSuffix && (
                <span class="pricing__suffix">{plan.priceSuffix}</span>
              )}
            </p>
            {plan.priceNote && (
              <p class="pricing__price-note">{plan.priceNote}</p>
            )}
          </div>

          <div class="pricing__scope">
            <p class="pricing__scope-label">Idéal pour</p>
            <ul class="pricing__chips">
              {plan.categories.map((c) => (
                <li class="pricing__chip">{c}</li>
              ))}
            </ul>
            {plan.duration && (
              <p class="pricing__duration">
                <Icon name="lucide:clock" />
                <span>{plan.duration}</span>
              </p>
            )}
          </div>

          <ul class="pricing__features">
            {plan.features.map((feature) => (
              <li class="pricing__feature">
                <Icon name="lucide:check" />
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <a class="pricing__cta" href={plan.ctaHref}>
            {plan.cta}
          </a>
        </li>
      ))
    }
  </ul>

  <aside class="pricing__notes">
    <p class="pricing__note">
      <strong>Hébergement</strong> — *Inclus pour les sites statiques.
      Nom de domaine à votre charge.
    </p>
    <p class="pricing__note">
      <strong>Révisions</strong> — un cycle correspond à un retour groupé du
      client. Les cycles supplémentaires font l'objet d'un devis.
    </p>
    <p class="pricing__note">
      <strong>Garantie</strong> — les dysfonctionnements sont corrigés pendant
      30 jours lorsqu'ils concernent ce qui avait été validé. Les ajouts,
      changements de contenu ou demandes différentes font l'objet d'un devis.
    </p>
    <p class="pricing__note">
      <strong>Maintenance Croissance</strong> — incluse pendant 3 mois pour
      les mises à jour de sécurité et la correction des dysfonctionnements.
      Un contrat de maintenance annuel optionnel peut être proposé ensuite.
    </p>
  </aside>
</section>

<style>
  .pricing__grid {
    list-style: none;
    margin: clamp(2.5rem, 5vh, 4rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 1.8vw, 1.25rem);
    align-items: stretch;
  }

  .pricing__card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    padding: clamp(1.25rem, 2.2vw, 1.75rem);
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .pricing__card:hover {
    border-color: rgba(0, 0, 0, 0.18);
  }

  .pricing__card--popular {
    border-color: rgba(0, 0, 0, 0.92);
    border-width: 2px;
    padding: calc(clamp(1.25rem, 2.2vw, 1.75rem) - 1px);
  }
  .pricing__card--popular:hover {
    border-color: rgba(0, 0, 0, 0.92);
  }

  .pricing__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
    border-radius: 999px;
    padding: 0.4rem 0.875rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    white-space: nowrap;
  }
  .pricing__badge :global(svg) {
    width: 12px;
    height: 12px;
  }

  .pricing__header {
    margin-bottom: 1.5rem;
  }
  .pricing__name {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
    color: rgba(0, 0, 0, 0.92);
  }
  .pricing__tagline {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
    color: rgba(0, 0, 0, 0.6);
  }

  .pricing__price-block {
    margin: 0 0 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .pricing__price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .pricing__amount {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 600;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: rgba(0, 0, 0, 0.92);
  }
  .pricing__suffix {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.85rem;
    color: rgba(0, 0, 0, 0.5);
  }
  .pricing__price-note {
    margin: 0.5rem 0 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1.4;
    color: rgba(0, 0, 0, 0.55);
  }

  .pricing__scope {
    margin: 0 0 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pricing__scope-label {
    margin: 0;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(0, 0, 0, 0.5);
  }
  .pricing__chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .pricing__chip {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1;
    padding: 0.4rem 0.6rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.05);
    color: rgba(0, 0, 0, 0.72);
    white-space: nowrap;
  }
  .pricing__card--popular .pricing__chip {
    background: rgba(0, 0, 0, 0.07);
  }
  .pricing__duration {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.82rem;
    color: rgba(0, 0, 0, 0.55);
  }
  .pricing__duration :global(svg) {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  .pricing__features {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
  }
  .pricing__feature {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.7);
  }
  .pricing__feature :global(svg) {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    stroke-width: 2;
    color: rgba(0, 0, 0, 0.55);
  }

  .pricing__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 999px;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.9);
    background: transparent;
    text-decoration: none;
    transition: background 200ms ease, border-color 200ms ease, color 200ms ease;
  }
  .pricing__cta:hover {
    background: rgba(0, 0, 0, 0.92);
    border-color: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
  }
  .pricing__card--popular .pricing__cta {
    background: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
    border-color: rgba(0, 0, 0, 0.92);
  }
  .pricing__card--popular .pricing__cta:hover {
    background: #000;
    border-color: #000;
  }

  .pricing__notes {
    margin: clamp(2rem, 4vh, 3rem) 0 0;
    padding: clamp(1.25rem, 2vw, 1.75rem);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    background: rgba(0, 0, 0, 0.02);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
  }
  .pricing__note {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.85rem;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.62);
  }
  .pricing__note strong {
    font-weight: 600;
    color: rgba(0, 0, 0, 0.82);
  }

  @media (max-width: 960px) {
    .pricing__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .pricing__notes {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .pricing__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
