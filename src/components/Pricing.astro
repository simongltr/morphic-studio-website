---
import { Icon } from "astro-icon/components";
import { pricingPlans } from "../data/pricing-plans";

const [featured, ...rest] = pricingPlans;
---

<section id="tarifs" class="section pricing">
  <p class="section__eyebrow">Tarifs</p>
  <h2 class="section__title">Notre offre tarifaire</h2>
  <p class="section__body">
    Un prix ferme si vous savez ce que vous voulez. Un cadrage gratuit si on
    doit en parler.
  </p>

  <article class="featured-card">
    <span class="featured-card__eyebrow">
      <Icon name="lucide:sparkles" />
      <span>Offre découverte</span>
    </span>

    <div class="featured-card__intro">
      <h3 class="featured-card__name">{featured.name}</h3>
      <p class="featured-card__tagline">{featured.tagline}</p>
      <p class="featured-card__price">
        <span class="featured-card__amount">{featured.price}</span>
        {featured.priceSuffix && (
          <span class="featured-card__suffix">{featured.priceSuffix}</span>
        )}
      </p>
      {featured.duration && (
        <p class="featured-card__duration">
          <Icon name="lucide:clock" />
          <span>Mise en ligne en {featured.duration}</span>
        </p>
      )}
    </div>

    <ul class="featured-card__features">
      {featured.features.map((feature) => (
        <li class="featured-card__feature">
          <Icon name={feature.icon} />
          <span>{feature.label}</span>
        </li>
      ))}
    </ul>

    <a class="featured-card__cta" href={featured.ctaHref}>
      {featured.cta}
    </a>
  </article>

  <ul class="pricing__grid">
    {
      rest.map((plan) => (
        <li
          class:list={[
            "pricing__card",
            { "pricing__card--popular": plan.popular },
          ]}
        >
          {plan.popular && (
            <span class="pricing__badge">
              <Icon name="lucide:sparkles" />
              <span>Le plus demandé</span>
            </span>
          )}

          <header class="pricing__header">
            <h3 class="pricing__name">{plan.name}</h3>
            <p class="pricing__tagline">{plan.tagline}</p>
          </header>

          <div class="pricing__price-block">
            <p class="pricing__price">
              <span class="pricing__amount">{plan.price}</span>
              {plan.priceSuffix && (
                <span class="pricing__suffix">{plan.priceSuffix}</span>
              )}
            </p>
            {plan.priceNote && (
              <p class="pricing__price-note">{plan.priceNote}</p>
            )}
          </div>

          <div class="pricing__scope">
            <p class="pricing__scope-label">Idéal pour</p>
            <ul class="pricing__chips">
              {plan.categories.map((c) => (
                <li class="pricing__chip">{c}</li>
              ))}
            </ul>
            {plan.duration && (
              <p class="pricing__duration">
                <Icon name="lucide:clock" />
                <span>{plan.duration}</span>
              </p>
            )}
          </div>

          <ul class="pricing__features">
            {plan.features.map((feature) => (
              <li class="pricing__feature">
                <Icon name={feature.icon} />
                <span>{feature.label}</span>
              </li>
            ))}
          </ul>

          <a class="pricing__cta" href={plan.ctaHref}>
            {plan.cta}
          </a>
        </li>
      ))
    }
  </ul>

  <aside class="pricing__notes">
    <p class="pricing__note">
      <span class="pricing__note-head">
        <Icon name="lucide:server" />
        <strong>Hébergement</strong>
      </span>
      <span class="pricing__note-body">
        *Inclus pour les sites statiques. Nom de domaine à votre charge.
      </span>
    </p>
    <p class="pricing__note">
      <span class="pricing__note-head">
        <Icon name="lucide:repeat" />
        <strong>Révisions</strong>
      </span>
      <span class="pricing__note-body">
        Un cycle correspond à un retour groupé du client. Les cycles
        supplémentaires font l'objet d'un devis.
      </span>
    </p>
    <p class="pricing__note">
      <span class="pricing__note-head">
        <Icon name="lucide:shield-check" />
        <strong>Garantie</strong>
      </span>
      <span class="pricing__note-body">
        Les dysfonctionnements sont corrigés pendant 30 jours lorsqu'ils
        concernent ce qui avait été validé. Les ajouts, changements de
        contenu ou demandes différentes font l'objet d'un devis.
      </span>
    </p>
    <p class="pricing__note">
      <span class="pricing__note-head">
        <Icon name="lucide:wrench" />
        <strong>Maintenance Croissance</strong>
      </span>
      <span class="pricing__note-body">
        Incluse pendant 3 mois pour les mises à jour de sécurité et la
        correction des dysfonctionnements. Un contrat de maintenance annuel
        optionnel peut être proposé ensuite.
      </span>
    </p>
  </aside>
</section>

<style>
  .pricing {
    --accent: #b45309;
    --accent-soft: rgba(180, 83, 9, 0.08);
    --accent-tint: rgba(180, 83, 9, 0.04);
  }

  /* ---------- Featured horizontal card ---------- */
  .featured-card {
    position: relative;
    margin: clamp(2.5rem, 5vh, 4rem) 0 clamp(1.25rem, 2vw, 1.75rem);
    padding: clamp(1.5rem, 2.5vw, 2rem) clamp(1.5rem, 2.5vw, 2.25rem);
    border: 2px solid var(--accent);
    border-radius: 16px;
    background:
      linear-gradient(
        135deg,
        var(--accent-tint) 0%,
        rgba(255, 255, 255, 0) 60%
      ),
      #ffffff;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.2fr) auto;
    column-gap: clamp(1.5rem, 3vw, 2.5rem);
    row-gap: 1.25rem;
    align-items: center;
  }

  .featured-card__eyebrow {
    position: absolute;
    top: -14px;
    left: clamp(1.5rem, 2.5vw, 2.25rem);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--accent);
    color: #ffffff;
    border-radius: 999px;
    padding: 0.4rem 0.875rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    white-space: nowrap;
  }
  .featured-card__eyebrow :global(svg) {
    width: 12px;
    height: 12px;
  }

  .featured-card__intro {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .featured-card__name {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0;
    color: rgba(0, 0, 0, 0.92);
  }
  .featured-card__tagline {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.62);
  }
  .featured-card__price {
    margin: 0.25rem 0 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .featured-card__amount {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 600;
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--accent);
  }
  .featured-card__suffix {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.5);
  }
  .featured-card__duration {
    margin: 0.25rem 0 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.85rem;
    color: rgba(0, 0, 0, 0.6);
  }
  .featured-card__duration :global(svg) {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  .featured-card__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem 1.25rem;
  }
  .featured-card__feature {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9rem;
    line-height: 1.45;
    color: rgba(0, 0, 0, 0.72);
  }
  .featured-card__feature :global(svg) {
    flex: 0 0 auto;
    width: 14px;
    height: 14px;
    margin-top: 3px;
    stroke-width: 2.2;
    color: var(--accent);
  }

  .featured-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.5rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: #ffffff;
    background: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    transition: background 200ms ease, border-color 200ms ease, transform 200ms ease;
  }
  .featured-card__cta:hover {
    background: #8a3f07;
    border-color: #8a3f07;
  }

  /* ---------- 3-column grid below ---------- */
  .pricing__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 1.8vw, 1.25rem);
    align-items: stretch;
  }

  .pricing__card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    padding: clamp(1.25rem, 2.2vw, 1.75rem);
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .pricing__card:hover {
    border-color: rgba(0, 0, 0, 0.18);
  }

  .pricing__card--popular {
    border-color: rgba(0, 0, 0, 0.92);
    border-width: 2px;
    padding: calc(clamp(1.25rem, 2.2vw, 1.75rem) - 1px);
  }
  .pricing__card--popular:hover {
    border-color: rgba(0, 0, 0, 0.92);
  }

  .pricing__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
    border-radius: 999px;
    padding: 0.4rem 0.875rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    white-space: nowrap;
  }
  .pricing__badge :global(svg) {
    width: 12px;
    height: 12px;
  }

  .pricing__header {
    margin-bottom: 1.5rem;
  }
  .pricing__name {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
    color: rgba(0, 0, 0, 0.92);
  }
  .pricing__tagline {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
    color: rgba(0, 0, 0, 0.6);
  }

  .pricing__price-block {
    margin: 0 0 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .pricing__price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .pricing__amount {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 600;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: rgba(0, 0, 0, 0.92);
  }
  .pricing__suffix {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.85rem;
    color: rgba(0, 0, 0, 0.5);
  }
  .pricing__price-note {
    margin: 0.5rem 0 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1.4;
    color: rgba(0, 0, 0, 0.55);
  }

  .pricing__scope {
    margin: 0 0 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .pricing__scope-label {
    margin: 0;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(0, 0, 0, 0.5);
  }
  .pricing__chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .pricing__chip {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1;
    padding: 0.4rem 0.6rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.05);
    color: rgba(0, 0, 0, 0.72);
    white-space: nowrap;
  }
  .pricing__card--popular .pricing__chip {
    background: rgba(0, 0, 0, 0.07);
  }
  .pricing__duration {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.82rem;
    color: rgba(0, 0, 0, 0.55);
  }
  .pricing__duration :global(svg) {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  .pricing__features {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
  }
  .pricing__feature {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.7);
  }
  .pricing__feature :global(svg) {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    margin-top: 2px;
    stroke-width: 2;
    color: rgba(0, 0, 0, 0.55);
  }

  .pricing__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 999px;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.9);
    background: transparent;
    text-decoration: none;
    transition: background 200ms ease, border-color 200ms ease, color 200ms ease;
  }
  .pricing__cta:hover {
    background: rgba(0, 0, 0, 0.92);
    border-color: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
  }
  .pricing__card--popular .pricing__cta {
    background: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
    border-color: rgba(0, 0, 0, 0.92);
  }
  .pricing__card--popular .pricing__cta:hover {
    background: #000;
    border-color: #000;
  }

  /* ---------- Notes ---------- */
  .pricing__notes {
    margin: clamp(1.5rem, 3vh, 2.25rem) 0 0;
    padding: clamp(1rem, 1.6vw, 1.25rem) clamp(1.25rem, 2vw, 1.5rem);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    column-gap: clamp(1.25rem, 2.5vw, 2rem);
    row-gap: 0.75rem;
  }
  .pricing__note {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.78rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.55);
  }
  .pricing__note-head {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(0, 0, 0, 0.82);
  }
  .pricing__note-head strong {
    font-weight: 600;
    font-size: 0.78rem;
  }
  .pricing__note-head :global(svg) {
    flex: 0 0 auto;
    width: 13px;
    height: 13px;
    stroke-width: 1.8;
    color: var(--accent);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1080px) {
    .featured-card {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
    .featured-card__cta {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }
  @media (max-width: 860px) {
    .featured-card {
      grid-template-columns: 1fr;
    }
    .featured-card__features {
      grid-template-columns: 1fr;
    }
    .pricing__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
