---
import { Icon } from "astro-icon/components";

const channels = [
  {
    icon: "lucide:mail",
    label: "Écrivez-nous",
    value: "hello@morphic.studio",
    href: "mailto:hello@morphic.studio",
    hint: "Réponse sous 24h ouvrées.",
  },
  {
    icon: "lucide:calendar",
    label: "Réservez un créneau",
    value: "30 min, en visio",
    href: "https://cal.com/morphic-studio",
    hint: "Pour un premier échange sans engagement.",
  },
  {
    icon: "lucide:phone",
    label: "Appelez-nous",
    value: "+33 1 23 45 67 89",
    href: "tel:+33123456789",
    hint: "Du lundi au vendredi, 9h–18h.",
  },
];
---

<section id="contact" class="section contact">
  <p class="section__eyebrow">Contact</p>
  <h2 class="section__title">Parlons de votre projet.</h2>
  <p class="section__body">
    Décrivez votre besoin en quelques lignes ci-dessous — nous revenons vers
    vous sous 24h ouvrées avec un premier retour clair.
  </p>

  <div class="contact__form-wrap">
    <form
      class="contact__form"
      id="contact-form"
      action="https://api.web3forms.com/submit"
      method="POST"
    >
      <input
        type="hidden"
        name="access_key"
        value="52ee40e4-0237-424a-aaf7-359170fcab67"
      />
      <input
        type="hidden"
        name="subject"
        value="Nouveau message — Morphic Studio"
      />
      <input type="hidden" name="from_name" value="Site Morphic Studio" />
      <input
        type="checkbox"
        name="botcheck"
        class="contact__form-bot"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <div class="contact__form-row">
        <label class="contact__field">
          <span class="contact__field-label">Nom</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            placeholder="Camille Martin"
          />
        </label>
        <label class="contact__field">
          <span class="contact__field-label">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="camille@exemple.com"
          />
        </label>
      </div>

      <label class="contact__field">
        <span class="contact__field-label">Votre projet</span>
        <textarea
          name="message"
          rows="5"
          required
          placeholder="Quelques lignes sur le besoin, le contexte, l'échéance."
        />
      </label>

      <div class="contact__form-foot">
        <button type="submit" class="contact__form-submit">
          <span>Envoyer</span>
          <Icon name="lucide:arrow-right" />
        </button>
        <p
          class="contact__form-status"
          id="contact-form-status"
          aria-live="polite"
        />
      </div>
    </form>
  </div>

  <div class="contact__channels-wrap">
    <p class="section__eyebrow contact__channels-eyebrow">Autres canaux</p>
    <h3 class="contact__channels-title">
      Vous préférez nous joindre autrement ?
    </h3>
    <ul class="contact__channels">
      {
        channels.map((channel) => (
          <li class="contact__channel">
            <span class="contact__channel-icon" aria-hidden="true">
              <Icon name={channel.icon} />
            </span>
            <p class="contact__channel-label">{channel.label}</p>
            {channel.href ? (
              <a class="contact__channel-value" href={channel.href}>
                {channel.value}
              </a>
            ) : (
              <p class="contact__channel-value">{channel.value}</p>
            )}
            <p class="contact__channel-hint">{channel.hint}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .contact {
    padding-top: clamp(2rem, 4vh, 4rem);
  }

  .contact__channels-wrap {
    margin: clamp(3rem, 6vh, 5rem) 0 0;
  }
  .contact__channels-eyebrow {
    margin: 0 0 0.75rem;
  }
  .contact__channels-title {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: clamp(1.25rem, 1.9vw, 1.5rem);
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 0 0 2rem;
    max-width: 36ch;
    color: rgba(0, 0, 0, 0.92);
  }
  .contact__channels {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .contact__channel {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .contact__channel-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    color: rgba(0, 0, 0, 0.75);
    margin-bottom: 1.25rem;
  }
  .contact__channel-icon :global(svg) {
    width: 20px;
    height: 20px;
    stroke-width: 1.5;
  }
  .contact__channel-label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: rgba(0, 0, 0, 0.5);
    margin: 0 0 0.5rem;
  }
  .contact__channel-value {
    display: inline-block;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.92);
    margin: 0;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  a.contact__channel-value:hover {
    border-bottom-color: rgba(0, 0, 0, 0.6);
  }
  .contact__channel-hint {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.55);
    margin: 0.5rem 0 0;
  }

  .contact__form-wrap {
    margin: clamp(2.5rem, 5vh, 4rem) 0 0;
    padding: clamp(2rem, 4vw, 3rem);
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .contact__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .contact__form-bot {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact__field-label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: rgba(0, 0, 0, 0.5);
  }
  .contact__field input,
  .contact__field textarea {
    width: 100%;
    border: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.18);
    padding: 0.625rem 0;
    background: transparent;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.92);
    outline: none;
    border-radius: 0;
    transition: border-color 200ms ease;
  }
  .contact__field textarea {
    resize: vertical;
    min-height: 120px;
  }
  .contact__field input::placeholder,
  .contact__field textarea::placeholder {
    color: rgba(0, 0, 0, 0.35);
  }
  .contact__field input:focus,
  .contact__field textarea:focus {
    border-bottom-color: rgba(0, 0, 0, 0.92);
  }

  .contact__form-foot {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .contact__form-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    border: 1px solid rgba(0, 0, 0, 0.92);
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 200ms ease, border-color 200ms ease;
  }
  .contact__form-submit:hover {
    background: #000;
    border-color: #000;
  }
  .contact__form-submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
  .contact__form-submit :global(svg) {
    width: 16px;
    height: 16px;
    stroke-width: 2;
  }

  .contact__form-status {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: rgba(0, 0, 0, 0.6);
    min-height: 1.45em;
  }
  .contact__form-status[data-state="success"] {
    color: rgba(0, 0, 0, 0.92);
  }
  .contact__form-status[data-state="error"] {
    color: #8a2a2a;
  }

  @media (max-width: 900px) {
    .contact__channels {
      grid-template-columns: 1fr;
    }
    .contact__form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("contact-form-status");
  if (form && status) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const submit = form.querySelector<HTMLButtonElement>(
        "button[type=submit]",
      );
      if (submit) submit.disabled = true;
      status.textContent = "Envoi en cours…";
      status.dataset.state = "pending";

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok && json.success) {
          form.reset();
          status.textContent =
            "Merci, votre message est bien arrivé. Nous revenons vers vous sous 24h ouvrées.";
          status.dataset.state = "success";
        } else {
          status.textContent =
            json.message ??
            "Une erreur est survenue. Réessayez ou contactez-nous par un autre moyen.";
          status.dataset.state = "error";
        }
      } catch {
        status.textContent =
          "Réseau indisponible. Réessayez plus tard ou contactez-nous par un autre moyen.";
        status.dataset.state = "error";
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  }
</script>
