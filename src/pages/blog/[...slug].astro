---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import { withBase } from "../../utils/url";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={`${post.data.title} — Morphic Studio`}>
  <Header />
  <main class="site">
    <article class="article">
      <div class="article__inner">
        <a class="article__back" href={withBase("/blog/")}>
          <Icon name="lucide:arrow-left" />
          <span>Retour au blog</span>
        </a>

        <p class="article__meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {dateFmt.format(post.data.pubDate)}
          </time>
        </p>
        <h1 class="article__title">{post.data.title}</h1>
        <p class="article__lede">{post.data.description}</p>

        <div class="article__hero">
          <img
            src={withBase(post.data.heroImage)}
            alt={post.data.heroAlt}
          />
        </div>

        <div class="article__body">
          <Content />
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .article {
    padding: clamp(6rem, 14vh, 10rem) clamp(1.5rem, 6vw, 6rem)
      clamp(4rem, 10vh, 8rem);
  }
  .article__inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .article__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 0.875rem;
    color: rgba(0, 0, 0, 0.55);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 200ms ease;
  }
  .article__back:hover {
    color: rgba(0, 0, 0, 0.9);
  }
  .article__back :global(svg) {
    width: 14px;
    height: 14px;
  }

  .article__meta {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: rgba(0, 0, 0, 0.5);
    text-transform: lowercase;
    margin: 0 0 1rem;
  }
  .article__title {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: clamp(2rem, 4.4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
    color: rgba(0, 0, 0, 0.92);
  }
  .article__lede {
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(1.0625rem, 1.3vw, 1.1875rem);
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.62);
    margin: 0 0 2.5rem;
    max-width: 56ch;
  }

  .article__hero {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    margin: 0 0 clamp(2.5rem, 5vh, 4rem);
    background: rgba(0, 0, 0, 0.03);
  }
  .article__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article__body {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(0, 0, 0, 0.78);
  }

  .article__body :global(h2) {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: clamp(1.375rem, 2.2vw, 1.75rem);
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 3rem 0 1rem;
    color: rgba(0, 0, 0, 0.92);
  }
  .article__body :global(h3) {
    font-family: "Space Grotesk", "Inter", sans-serif;
    font-weight: 500;
    font-size: 1.25rem;
    line-height: 1.3;
    margin: 2.25rem 0 0.75rem;
    color: rgba(0, 0, 0, 0.9);
  }
  .article__body :global(p) {
    margin: 0 0 1.25rem;
  }
  .article__body :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 200ms ease;
  }
  .article__body :global(a:hover) {
    color: rgba(0, 0, 0, 0.95);
  }
  .article__body :global(ul),
  .article__body :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.25rem;
  }
  .article__body :global(li) {
    margin: 0 0 0.5rem;
  }
  .article__body :global(blockquote) {
    margin: 1.75rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    border-left: 2px solid rgba(0, 0, 0, 0.2);
    color: rgba(0, 0, 0, 0.68);
    font-style: italic;
  }
  .article__body :global(code) {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.875em;
    background: rgba(0, 0, 0, 0.06);
    padding: 0.125em 0.375em;
    border-radius: 4px;
  }
  .article__body :global(pre) {
    background: rgba(0, 0, 0, 0.92);
    color: #fafaf8;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    overflow-x: auto;
    margin: 1.75rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  .article__body :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  .article__body :global(hr) {
    border: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    margin: 2.5rem 0;
  }
</style>
